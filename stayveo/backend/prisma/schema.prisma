// ─── StayVeo Prisma Schema ──────────────────────────────────────────────
// Mapped to the EXISTING PostgreSQL database on Supabase.
// All models match the real DB tables. Enums use PascalCase names with
// @map() to preserve the actual lowercase Postgres enum values.
// ────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────
// PascalCase in code → lowercase in Postgres via @map on enum name

enum UserRole {
  STUDENT  @map("student")
  PROVIDER @map("provider")

  @@map("user_role")
}

enum GenderType {
  MALE             @map("male")
  FEMALE           @map("female")
  OTHER            @map("other")
  PREFER_NOT_TO_SAY @map("prefer_not_to_say")

  @@map("gender_type")
}

enum FoodPreference {
  VEG           @map("veg")
  NONVEG        @map("nonveg")
  JAIN          @map("jain")
  VEGAN         @map("vegan")
  NO_PREFERENCE @map("no_preference")

  @@map("food_pref")
}

enum LifestyleType {
  EARLY_BIRD @map("early_bird")
  NIGHT_OWL  @map("night_owl")
  FLEXIBLE   @map("flexible")

  @@map("lifestyle_type")
}

enum StudyHabit {
  QUIET    @map("quiet")
  FLEXIBLE @map("flexible")
  NORMAL   @map("normal")

  @@map("study_habit")
}

enum SocialLevel {
  INTROVERT @map("introvert")
  EXTROVERT @map("extrovert")
  AMBIVERT  @map("ambivert")

  @@map("social_level")
}

enum ServiceCategory {
  PG       @map("pg")
  TIFFIN   @map("tiffin")
  LAUNDRY  @map("laundry")
  CLEANING @map("cleaning")

  @@map("service_category")
}

enum ServiceType {
  PG
  TIFFIN
  LAUNDRY
  CLEANING

  @@map("provider_service_type")
}

enum FoodType {
  VEG    @map("veg")
  NONVEG @map("nonveg")
  JAIN   @map("jain")
  VEGAN  @map("vegan")

  @@map("food_type")
}

enum PricingModel {
  PER_KG   @map("per_kg")
  PER_ITEM @map("per_item")

  @@map("pricing_model")
}

enum CleanType {
  BASIC      @map("basic")
  DEEP_CLEAN @map("deep_clean")

  @@map("clean_type")
}

enum DocType {
  ID_PROOF       @map("id_proof")
  BUSINESS_PROOF @map("business_proof")

  @@map("doc_type")
}

// ─── USERS ──────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone_number String   @unique @db.VarChar(15)
  role         UserRole
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  studentProfile StudentProfile?
  provider       Provider?
  providerProfile ProviderProfile?

  @@map("users")
}

// ─── STUDENT PROFILES ───────────────────────────────────────────────────

model StudentProfile {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String          @unique @map("user_id") @db.Uuid
  fullName           String          @map("name")
  college            String
  year               Int?
  gender             GenderType?
  foodPreference     FoodPreference? @map("food_preference")
  sleepSchedule      LifestyleType?  @map("lifestyle")
  cleanlinessLevel   Int?            @map("cleanliness_level")
  studyHabits        StudyHabit?     @map("study_habits")
  personalityType    SocialLevel?    @map("personality_type")
  locationPreference String?         @map("location_preference")
  budget             String?
  profileImageUrl    String?         @map("profile_image_url")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_profiles")
}

// ─── PROVIDERS ──────────────────────────────────────────────────────────

model Provider {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  name              String
  businessName      String   @map("business_name")
  phone_number      String   @db.VarChar(15)
  location          String?
  latitude          Decimal  @db.Decimal(9, 6)
  longitude         Decimal  @db.Decimal(9, 6)
  service_radius_km Decimal? @db.Decimal(5, 2)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  services     Service[]
  mediaUploads MediaUpload[]
  documents    Document[]

  @@map("providers")
}

// ─── PROVIDER ONBOARDING PROFILE ───────────────────────────────────────

model ProviderProfile {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @unique @map("user_id") @db.Uuid
  phone      String   @unique @db.VarChar(15)
  name       String?
  email      String?
  isVerified Boolean  @default(false) @map("is_verified")
  otpVerified Boolean @default(false) @map("otp_verified")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  services      ProviderService[]
  verifications ProviderVerification[]

  @@map("provider_profiles")
}

model ProviderService {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId String      @map("provider_id") @db.Uuid
  type       ServiceType

  provider        ProviderProfile  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  pgDetails       PGDetails?
  tiffinDetails   TiffinDetails?
  laundryDetails  LaundryDetails?
  cleaningDetails CleaningDetails?

  @@unique([providerId, type])
  @@map("provider_services")
}

model PGDetails {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId String   @unique @map("service_id") @db.Uuid
  pgName    String   @map("pg_name")
  address   String
  roomType  String   @map("room_type")
  minPrice  Float    @map("min_price")
  amenities String[]
  photos    String[]

  service ProviderService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("pg_details")
}

model TiffinDetails {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId   String   @unique @map("service_id") @db.Uuid
  name        String
  price       Float
  mealsPerDay Int      @map("meals_per_day")
  photos      String[]

  service ProviderService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("tiffin_details")
}

model LaundryDetails {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId String   @unique @map("service_id") @db.Uuid
  pricing   String
  photos    String[]

  service ProviderService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("laundry_details")
}

model CleaningDetails {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId String   @unique @map("service_id") @db.Uuid
  pricing   String
  photos    String[]

  service ProviderService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("cleaning_details")
}

model ProviderVerification {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId String  @map("provider_id") @db.Uuid
  idType     String  @map("id_type")
  idNumber   String  @map("id_number")
  isVerified Boolean @default(false) @map("is_verified")

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, idType])
  @@map("provider_verifications")
}

// ─── SERVICES (junction: provider ↔ service types) ──────────────────────

model Service {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId  String          @map("provider_id") @db.Uuid
  serviceType ServiceCategory @map("service_type")

  // Relations
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, serviceType])
  @@map("services")
}

// ─── PG ROOMS ───────────────────────────────────────────────────────────

model PGRoom {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id String   @db.Uuid
  pg_name     String
  address     String
  room_types  Json?
  min_price   Decimal? @db.Decimal(10, 2)
  max_price   Decimal? @db.Decimal(10, 2)
  amenities   Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("pg_rooms")
}

// ─── TIFFIN SERVICES ────────────────────────────────────────────────────

model TiffinService {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id       String    @db.Uuid
  kitchen_name      String
  foodType          FoodType? @map("food_type")
  meal_options      Json?
  monthly_price     Decimal?  @db.Decimal(10, 2)
  delivery_range_km Decimal?  @db.Decimal(5, 2)
  delivery_timing   String?
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("tiffin_services")
}

// ─── LAUNDRY SERVICES ───────────────────────────────────────────────────

model LaundryService {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id       String        @db.Uuid
  pricing_model     PricingModel?
  price             Decimal?      @db.Decimal(10, 2)
  pickup_frequency  String?
  delivery_time     String?
  service_radius_km Decimal?      @db.Decimal(5, 2)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("laundry_services")
}

// ─── CLEANING SERVICES ──────────────────────────────────────────────────

model CleaningService {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id       String     @db.Uuid
  service_type      CleanType?
  basic_price       Decimal?   @db.Decimal(10, 2)
  deep_clean_price  Decimal?   @db.Decimal(10, 2)
  staff_available   Int?
  available_slots   Json?
  service_radius_km Decimal?   @db.Decimal(5, 2)
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("cleaning_services")
}

// ─── MEDIA UPLOADS ──────────────────────────────────────────────────────

model MediaUpload {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId  String          @map("provider_id") @db.Uuid
  serviceType ServiceCategory @map("service_type")
  fileUrl     String          @map("file_url")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("media_uploads")
}

// ─── DOCUMENTS ──────────────────────────────────────────────────────────

model Document {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId String   @map("provider_id") @db.Uuid
  docType    DocType  @map("doc_type")
  fileUrl    String   @map("file_url")
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ─── BOOKING ENUMS ──────────────────────────────────────────────────────

enum BookingStatus {
  NEW          @map("new")
  ACCEPTED     @map("accepted")
  IN_PROGRESS  @map("in_progress")
  COMPLETED    @map("completed")
  REJECTED     @map("rejected")

  @@map("booking_status")
}

enum VisitStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  COMPLETED @map("completed")

  @@map("visit_status")
}

enum PaymentType {
  RENT     @map("rent")
  LAUNDRY  @map("laundry")
  CLEANING @map("cleaning")
  TIFFIN   @map("tiffin")

  @@map("payment_type")
}

enum PaymentStatus {
  PAID    @map("paid")
  PENDING @map("pending")

  @@map("payment_status")
}

// ─── BOOKINGS ───────────────────────────────────────────────────────────

model Booking {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  providerId   String        @map("provider_id") @db.Uuid
  roomId       String?       @map("room_id") @db.Uuid
  serviceType  String?       @map("service_type")
  roomType     String?       @map("room_type")
  status       BookingStatus @default(NEW)
  bookingDate  DateTime      @map("booking_date") @db.Date
  bookingTime  String        @map("booking_time")
  price        Decimal       @db.Decimal(10, 2)
  studentName  String?       @map("student_name")
  studentPhone String?       @map("student_phone") @db.VarChar(15)
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  visitRequests VisitRequest[]
  payments      Payment[]

  @@map("bookings")
}

// ─── VISIT REQUESTS ─────────────────────────────────────────────────────

model VisitRequest {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId    String      @map("booking_id") @db.Uuid
  userId       String      @map("user_id") @db.Uuid
  providerId   String      @map("provider_id") @db.Uuid
  visitDate    DateTime    @map("visit_date") @db.Date
  visitTime    String      @map("visit_time")
  status       VisitStatus @default(PENDING)
  instructions String?
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("visit_requests")
}

// ─── PROFILE VIEWS ──────────────────────────────────────────────────────

model ProfileView {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId String   @map("provider_id") @db.Uuid
  viewerId   String?  @map("viewer_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("profile_views")
}

// ─── PAYMENTS ───────────────────────────────────────────────────────────

model Payment {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId  String?       @map("booking_id") @db.Uuid
  userId     String        @map("user_id") @db.Uuid
  providerId String        @map("provider_id") @db.Uuid
  amount     Decimal       @db.Decimal(10, 2)
  type       PaymentType
  status     PaymentStatus @default(PENDING)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@map("payments")
}
